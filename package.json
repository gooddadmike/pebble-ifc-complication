{
  "name": "pebble-ifc-complication",
  "version": "0.1.1",
  "description": "International Fixed Calendar complication/widget for Pebble watchfaces",
  "main": "ifc-complication.js",
  "keywords": [
    "pebble-package",
    "pebble",
    "rebble",
    "watchface",
    "complication",
    "widget",
    "calendar",
    "ifc"
  ],
  "pebble": {
    "displayName": "pebble-ifc-complication",
    "sdkVersion": "3",
    "enableMultiJS": true,
    "targetPlatforms": ["aplite", "basalt", "chalk", "diorite", "emery"]
  },
  "dependencies": {
    "@gooddadmike/ifc-js": "^1.0.1"
  },
  "homepage": "https://github.com/gooddadmike/pebble-ifc-complication#readme",
  "bugs": {
    "url": "https://github.com/gooddadmike/pebble-ifc-complication/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/gooddadmike/pebble-ifc-complication.git"
  },
  "license": "MIT",
  "author": "mike@searcy.me"
}
